{
  "name": "webhook-cap-server",
  "version": "1.0.0",
  "private": true,
  "description": "CAP TypeScript server exposing a /webhook endpoint",
  "license": "ISC",
  "scripts": {
    "dev": "PORT=4006 cds watch",
    "watch": "PORT=4006 cds watch",
    "build": "tsc -p tsconfig.json",
    "build:cf": "tsc -p tsconfig.json",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sap/cds": "^9.5.1",
    "express": "^4.22.1",
    "@sap/xssec": "^4.11.2",
    "@sap/xsenv": "^4.0.3",
    "passport": "^0.7.0",
    "jwt-decode": "3.1.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.5.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/passport": "^1.0.16"
  },
  "cds": {
    "requires": {
      "auth": "jwt"
    },
    "[development]": {
      "requires": {
        "auth": "mocked"
      }
    }
  }
}
