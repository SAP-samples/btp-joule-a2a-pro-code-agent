{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/webhook$",
      "target": "/webhook",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/api/(.*)$",
      "target": "/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^(?!(/login|/login/callback|/logout))(.*)$",
      "target": "$2",
      "localDir": "resources",
      "authenticationType": "xsuaa",
      "cacheControl": "no-cache"
    }
  ]
}
